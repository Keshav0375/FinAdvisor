# FinAdvisor — Environment Variables
# Copy to .env and fill in real values. Never commit .env.

# LLM Providers
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME
OPENAI_API_KEY=sk-REPLACE_ME
GOOGLE_API_KEY=AIza-REPLACE_ME
LITELLM_MASTER_KEY=sk-litellm-local

# Embeddings
VOYAGE_API_KEY=voyage-REPLACE_ME

# Database (used by backend when running outside Docker)
DATABASE_URL=postgresql+asyncpg://finadvisor:localdev@localhost:5432/finadvisor

# PII Redaction
PII_MODE=regex
GCP_PROJECT_ID=

# Kong
KONG_URL=http://localhost:8001

# LangFuse
LANGFUSE_HOST=http://localhost:3030
LANGFUSE_PUBLIC_KEY=pk-lf-REPLACE_ME
LANGFUSE_SECRET_KEY=sk-lf-REPLACE_ME

# Auth
JWT_SECRET=local-dev-secret

# LangFuse internal
NEXTAUTH_SECRET=langfuse-dev-secret
